# Base URL of the deployed app (preview, staging, or http://localhost:5173).
E2E_BASE_URL=https://guard.citerlabs.com

# --- Optional: programmatic Clerk sign-in -----------------------------------
# Leave blank to use the manual storageState flow (recommended on Clerk dev
# instances, which sometimes block automated sign-in with bot detection).
#
# To use programmatic sign-in:
#   1. Create a dedicated test user in your Clerk dashboard.
#   2. Set the values below.
#   3. Run: npm run e2e:auth   (creates playwright/.auth/user.json)
#   4. Run: npm run e2e
E2E_CLERK_USER=
E2E_CLERK_PASSWORD=

# Required by @clerk/testing for programmatic sign-in. Get from Clerk dashboard.
# Only needed if E2E_CLERK_USER is set.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=pk_test_cG9saXRlLXBhbmdvbGluLTY3LmNsZXJrLmFjY291bnRzLmRldiQ
