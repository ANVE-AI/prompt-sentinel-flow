# Copy to .env, then `docker compose up -d` from this directory.
# All values are environment-only — nothing is baked into images.

# --- Required ---
# AES-GCM derivation secret for encrypted provider keys (api_keys.provider_key_encrypted).
# Generate with: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=change-me-with-openssl-rand-hex-32

# --- Required if you want to use the hosted dashboard auth ---
# Get from https://clerk.com → API keys (publishable + secret).
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Optional ---
# Enables the LLM-backed intent + ML classifiers. Without it those layers
# silently fail-open and the engine falls back to its rule layers.
LOVABLE_API_KEY=

# Optional. Bearer token for the pluggable trained-classifier endpoint
# (ProtectAI / Llama Prompt Guard / your own HF Inference Endpoint).
CLASSIFIER_API_KEY=

# --- Networking ---
POSTGRES_PASSWORD=anveguard_local_dev
POSTGRES_PORT=54322
EDGE_PORT=54321
DASHBOARD_PORT=8080

# Comma-separated origins allowed to call the dashboard function.
ALLOWED_ORIGINS=http://localhost:8080
