# Frontend (Vite) — these are bundled into the public build.
# The publishable key is the Supabase **anon** key (intentionally public).
# Service role keys must NEVER live here — they belong only in edge-function env.
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-jwt"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Clerk publishable key (also public — safe to bundle).
# VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# === Edge function secrets (set in Supabase project, NOT here) ===
# These must be configured via `supabase secrets set` or the Supabase dashboard.
# They are listed here only for documentation; do not put real values in any .env*.
#   SUPABASE_SERVICE_ROLE_KEY    — service role JWT (very sensitive)
#   KEY_ENCRYPTION_SECRET         — AES-GCM key derivation secret
#   CLERK_SECRET_KEY              — if/when used server-side
#   ALLOWED_ORIGINS               — comma-separated origins for dashboard CORS (H3)
